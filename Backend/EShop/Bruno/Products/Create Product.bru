meta {
  name: Create Product
  type: http
  seq: 3
}

post {
  url: {{baseUrl}}/api/products
  body: json
  auth: bearer
}

auth:bearer {
  token: {{sellerToken}}
}

body:json {
  {
    "name": "Laptop ASUS",
    "description": "15-inch laptop, 16GB RAM",
    "price": 29999.99,
    "quantity": 10
  }
}
